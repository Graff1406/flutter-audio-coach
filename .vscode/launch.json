{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter Android Emulator",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "deviceId": "emulator-5554"
    },
    {
      "name": "Flutter Chrome",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "deviceId": "chrome"
    },
    {
      "name": "Web localhost:5050",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "toolArgs": [
        "-d",
        "web-server",
        "--web-port",
        "5050",
        "--web-hostname",
        "localhost",
        "--no-web-resources-cdn"
      ]
    }
  ]
}
